{
  "version": 2,
  "framework": null,
  "buildCommand": "pnpm -w run build:vercel",
  "outputDirectory": "artifacts/daycare-website/dist/public",
  "functions": {
    "api/index.ts": {
      "memory": 1024,
      "maxDuration": 30
    }
  },
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/index.ts"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
